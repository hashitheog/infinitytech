<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head_css") %>
</head>

<body>

    <%- include("partials/loader") %>

    <%- include("partials/navbar") %>

    <main>

        <!--================= Banner section start =================-->
        <section class="vl-breadcrumb-bg p-relative z-index-1 fix pt-200 pb--70" style="background-image: url(/img/banner/vl-breadcrumb-bg.png);">
            <div class="container">
                <div class="row">
                    <div class="col-xl-6 col-md-6 mb-30">
                        <div class="vl-breadcrumb">
                            <h1 class="vl-fs-60 vl-white">Engagement Packages</h1>
                            <div class="vl-breadcrumb-list">
                                <span><a href="index">Home</a></span>
                                <span class="dvir"><i class="fa-solid fa-angle-right"></i></span>
                                <span class="active"><a href="#">Solution Packages</a></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-6 col-md-6 mb-30">
                        <div class="vl-hero-img p-relative d-none d-lg-block">
                            <div class="vl-hero-shape-4">
                                <div class="vl-shape-2">
                                    <img src="/img/icons/vl-emoji-4.2.svg" alt="">
                                </div>
                                <div class="vl-shape-3">
                                    <img src="/img/icons/vl-emoji-4.3.svg" alt="">
                                </div>
                            </div>
                            <div class="vl-breadcrumb-fan">
                                <img class="w-100" src="/img/icons/vl-fan-sm.svg" alt="">
                            </div>
                            <div class="vl-breadcrumb-img text-center">
                                <img src="/img/banner/infinity-hero-transparent.png" alt="Infinity Tech Packages" style="transform: scale(0.99); transform-origin: center center; max-height: 352px;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!--================= Banner section End =================-->

        <!--================= Packages section start =================-->
        <section class="vl-pricing pt-100 pb-70">
            <div class="container">
                <div class="vl-section-title-wrapper text-center mb-60">
                    <div class="vl-section-subheading">
                        <h4 class="vl-section-subtitle-6 vl-upper">OUR SOLUTION PACKAGES</h4>
                    </div>
                    <h2 class="vl-section-title vl-section-title-2 pt-16">Tailored Engineering Packages <br> Built for Your Business</h2>
                </div>

                <div class="row">
                    <!-- Package 1: Website Dev & Design -->
                    <div class="col-lg-4 col-md-6">
                        <div class="vl-pricing-box p-relative z-index-1 mb-30">
                            <div class="vl-pricing-box-price vl-pricing-box-price-iner">
                                <h3 class="price-title pb-16">Website Dev & Design</h3>
                                <h2 class="price-number">Tailored <span>Quote</span></h2>
                            </div>

                            <div class="vl-pricing-box-content">
                                <p>Modern responsive web application development with sub-2 second load times and SEO optimization.</p>
                            </div>
                            <div class="vl-pricing-box-list">
                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Custom UI/UX Design System</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Node.js & React Web Build</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Full Mobile Responsiveness</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Search Engine Optimization (SEO)</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>3 Months Free Maintenance</p>
                                    </div>
                                </div>
                            </div>

                            <div class="vl-about-inner-btn mt-12">
                                <a href="/service-web-dev" class="vl-iner-btn">Select Package <span><i class="fa-light fa-arrow-right"></i></span></a>
                            </div>
                        </div>
                    </div>
                    <!-- Package 1 End -->

                    <!-- Package 2: Mobile App Development -->
                    <div class="col-lg-4 col-md-6">
                        <div class="vl-pricing-box active active-2 p-relative z-index-1 mb-30">
                            <div class="vl-pricing-box-price vl-pricing-box-price-iner">
                                <h3 class="price-title pb-16">Mobile App Development</h3>
                                <h2 class="price-number">Custom <span>Package</span></h2>
                            </div>

                            <div class="vl-pricing-box-content active-border">
                                <p>Native iOS & Android mobile applications engineered for fast performance and offline sync.</p>
                            </div>
                            <div class="vl-pricing-box-list">
                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>iOS & Android Native Build</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Offline Data Caching Engine</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Mobile Money API Integration</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Push Notifications Gateway</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>App Store & Play Store Release</p>
                                    </div>
                                </div>
                            </div>
                            <div class="vl-about-inner-btn active-btn mt-12">
                                <a href="/service-mobile-app" class="vl-iner-btn">Select Package <span><i class="fa-light fa-arrow-right"></i></span></a>
                            </div>
                        </div>
                    </div>
                    <!-- Package 2 End -->

                    <!-- Package 3: Custom SaaS & School Platform -->
                    <div class="col-lg-4 col-md-6">
                        <div class="vl-pricing-box p-relative z-index-1 mb-30">
                            <div class="vl-pricing-box-price vl-pricing-box-price-iner">
                                <h3 class="price-title pb-16">Custom SaaS & School Platform</h3>
                                <h2 class="price-number">Enterprise <span>SaaS</span></h2>
                            </div>

                            <div class="vl-pricing-box-content">
                                <p>All-in-one cloud management software for schools, universities, and enterprise organizations.</p>
                            </div>
                            <div class="vl-pricing-box-list">
                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Multi-Tenant Cloud Database</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Automated Tuition & Fee Invoicing</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>WhatsApp & SMS Parent Alerts</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>Student & Attendance Records</p>
                                    </div>
                                </div>

                                <div class="vl-pricing-box-list-box mb-20">
                                    <div class="vl-icon vl-icon-2">
                                        <span><i class="fa-regular fa-check"></i></span>
                                    </div>
                                    <div class="vl-icon-content">
                                        <p>24/7 Wadada Debka Support</p>
                                    </div>
                                </div>
                            </div>
                            <div class="vl-about-inner-btn mt-12">
                                <a href="/service-school-saas" class="vl-iner-btn">Select Package <span><i class="fa-light fa-arrow-right"></i></span></a>
                            </div>
                        </div>
                    </div>
                    <!-- Package 3 End -->

                </div>
