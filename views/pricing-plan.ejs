                    <div class="col-lg-9 mb-30">
                        <div class="vl-brand-marquee-container">
                            <div class="vl-brand-marquee-track">
                                <div class="circular-brand-item" title="Ministry of Foreign Affairs">
                                    <img src="/img/brand/somali-mofa-orig.jpg" alt="Ministry of Foreign Affairs" class="circular-brand-logo">
                                </div>
                                <div class="circular-brand-item" title="Ministry of Environment">
                                    <img src="/img/brand/somali-moecc-orig.png" alt="Ministry of Environment" class="circular-brand-logo">
                                </div>
                                <div class="circular-brand-item" title="Ministry of Defence">
                                    <img src="/img/brand/somali-modefence-orig.jpg" alt="Ministry of Defence" class="circular-brand-logo">
                                </div>
                                <div class="circular-brand-item" title="Somali Primary & Secondary Schools">
                                    <img src="/img/brand/somali-spss-orig.png" alt="Somali Primary & Secondary Schools" class="circular-brand-logo">
                                </div>
                                <div class="circular-brand-item" title="Al-Muasir Institution">
                                    <img src="/img/brand/somali-muasir-orig.png" alt="Al-Muasir Institution" class="circular-brand-logo">
                                </div>

                                <!-- Set 2 -->
                                <div class="circular-brand-item" title="Ministry of Foreign Affairs">
                                    <img src="/img/brand/somali-mofa-orig.jpg" alt="Ministry of Foreign Affairs" class="circular-brand-logo">
                                </div>
                                <div class="circular-brand-item" title="Ministry of Environment">
                                    <img src="/img/brand/somali-moecc-orig.png" alt="Ministry of Environment" class="circular-brand-logo">
                                </div>
                                <div class="circular-brand-item" title="Ministry of Defence">
                                    <img src="/img/brand/somali-modefence-orig.jpg" alt="Ministry of Defence" class="circular-brand-logo">
                                </div>
                                <div class="circular-brand-item" title="Somali Primary & Secondary Schools">
                                    <img src="/img/brand/somali-spss-orig.png" alt="Somali Primary & Secondary Schools" class="circular-brand-logo">
                                </div>
                                <div class="circular-brand-item" title="Al-Muasir Institution">
                                    <img src="/img/brand/somali-muasir-orig.png" alt="Al-Muasir Institution" class="circular-brand-logo">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
