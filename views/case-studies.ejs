<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head_css") %>
</head>

<body>

    <%- include("partials/loader") %>

    <%- include("partials/navbar") %>

    <main>

        <!--================= Banner section start =================-->
        <section class="vl-breadcrumb-bg p-relative z-index-1 fix pt-200 pb--70" style="background-image: url(/img/banner/vl-breadcrumb-bg.png);">
            <div class="container">
                <div class="row">
                    <div class="col-xl-6 col-md-6 mb-30">
                        <div class="vl-breadcrumb">
                            <h1 class="vl-fs-60 vl-white">Case Studies</h1>
                            <div class="vl-breadcrumb-list">
                                <span><a href="index">Home</a></span>
                                <span class="dvir"><i class="fa-solid fa-angle-right"></i></span>
                                <span class="active"><a href="#">Case Studies</a></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-6 col-md-6 mb-30">
                        <div class="vl-hero-img p-relative">
                            <div class="vl-hero-shape-4">
                                <div class="vl-shape-2">
                                    <img src="/img/icons/vl-emoji-4.2.svg" alt="">
                                </div>
                                <div class="vl-shape-3">
                                    <img src="/img/icons/vl-emoji-4.3.svg" alt="">
                                </div>
                            </div>
                            <div class="vl-breadcrumb-fan">
                                <img class="w-100" src="/img/icons/vl-fan-sm.svg" alt="">
                            </div>
                            <div class="vl-breadcrumb-img text-center">
                                <img src="/img/banner/infinity-hero-transparent.png" alt="Infinity Tech Case Studies" style="transform: scale(0.90); transform-origin: center center; max-height: 320px;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!--================= Banner section End =================-->

        <!--================= Case Studies section start =================-->
        <section class="vl-gallery p-relative z-index-1 pt-100 pb-70">
            <div class="container">
                <div class="vl-section-title-wrapper text-center mb-60">
                    <div class="vl-section-subheading">
                        <h4 class="vl-section-subtitle-6 vl-upper">PROOF OF EXCELLENCE</h4>
                    </div>
                    <h2 class="vl-section-title vl-section-title-2 pt-16">Our Proven Engineering Projects <br> Across Somalia</h2>
                </div>

                <div class="row">

                    <!-- Case Study 1: Mobile App -->
                    <div class="col-lg-4 col-md-6">
                        <div class="vl-gallery-testimonial-2 br-4 fix p-relative mb-30 z-index-1">
                            <div class="vl-gallery-testimonial-2-image">
                                <img class="w-100" src="/img/studies/case-mobile-app.jpg" alt="Mogadishu Mobile Commerce & Wallet App">
                            </div>
                            <div class="vl-gallery-testimonial-2-con">
                                <h3 class="vl-gallery-testimonial-2-title"><a href="/service-mobile-app">Mogadishu Mobile Commerce & Wallet App</a></h3>
                            </div>
                            <div class="vl-gallery-poligon">
                                <h3><a href="/service-mobile-app">View Project</a></h3>
                                <a href="/service-mobile-app"><span class="blu-bg"><i class="fa-regular fa-arrow-right"></i></span></a>
                            </div>
                        </div>
                    </div>

                    <!-- Case Study 2: Website Dev -->
                    <div class="col-lg-4 col-md-6">
                        <div class="vl-gallery-testimonial-2 br-4 fix p-relative mb-30 z-index-1">
                            <div class="vl-gallery-testimonial-2-image">
                                <img class="w-100" src="/img/studies/case-website-dev.jpg" alt="Enterprise Web Application & Portal">
                            </div>
                            <div class="vl-gallery-testimonial-2-con">
                                <h3 class="vl-gallery-testimonial-2-title"><a href="/service-web-dev">Enterprise Web Application & Portal</a></h3>
                            </div>
                            <div class="vl-gallery-poligon">
                                <h3><a href="/service-web-dev">View Project</a></h3>
                                <a href="/service-web-dev"><span class="blu-bg"><i class="fa-regular fa-arrow-right"></i></span></a>
                            </div>
                        </div>
                    </div>

                    <!-- Case Study 3: School SaaS -->
                    <div class="col-lg-4 col-md-6">
                        <div class="vl-gallery-testimonial-2 br-4 fix p-relative mb-30 z-index-1">
                            <div class="vl-gallery-testimonial-2-image">
                                <img class="w-100" src="/img/studies/case-saas-platform.jpg" alt="Somali School SaaS Management Platform">
                            </div>
                            <div class="vl-gallery-testimonial-2-con">
                                <h3 class="vl-gallery-testimonial-2-title"><a href="/service-school-saas">Somali School SaaS Management Platform</a></h3>
                            </div>
                            <div class="vl-gallery-poligon">
                                <h3><a href="/service-school-saas">View Project</a></h3>
                                <a href="/service-school-saas"><span class="blu-bg"><i class="fa-regular fa-arrow-right"></i></span></a>
                            </div>
                        </div>
                    </div>

                    <!-- Case Study 4: Somali Mobile Logistics -->
                    <div class="col-lg-4 col-md-6">
                        <div class="vl-gallery-testimonial-2 br-4 fix p-relative mb-30 z-index-1">
                            <div class="vl-gallery-testimonial-2-image">
                                <img class="w-100" src="/img/blog/somali-blog-1.jpg" alt="Mobile Logistics & Order Tracking App">
                            </div>
                            <div class="vl-gallery-testimonial-2-con">
                                <h3 class="vl-gallery-testimonial-2-title"><a href="/service-mobile-app">Mobile Logistics & Order Tracking App</a></h3>
                            </div>
                            <div class="vl-gallery-poligon">
                                <h3><a href="/service-mobile-app">View Project</a></h3>
                                <a href="/service-mobile-app"><span class="blu-bg"><i class="fa-regular fa-arrow-right"></i></span></a>
                            </div>
                        </div>
                    </div>

                    <!-- Case Study 5: School SaaS Attendance -->
                    <div class="col-lg-4 col-md-6">
                        <div class="vl-gallery-testimonial-2 br-4 fix p-relative mb-30 z-index-1">
                            <div class="vl-gallery-testimonial-2-image">
                                <img class="w-100" src="/img/blog/somali-blog-2.jpg" alt="School SaaS Attendance & SMS Gateway">
                            </div>
                            <div class="vl-gallery-testimonial-2-con">
                                <h3 class="vl-gallery-testimonial-2-title"><a href="/service-school-saas">School SaaS Attendance & SMS Gateway</a></h3>
                            </div>
                            <div class="vl-gallery-poligon">
                                <h3><a href="/service-school-saas">View Project</a></h3>
                                <a href="/service-school-saas"><span class="blu-bg"><i class="fa-regular fa-arrow-right"></i></span></a>
                            </div>
                        </div>
                    </div>

                    <!-- Case Study 6: Web Dashboard -->
                    <div class="col-lg-4 col-md-6">
                        <div class="vl-gallery-testimonial-2 br-4 fix p-relative mb-30 z-index-1">
                            <div class="vl-gallery-testimonial-2-image">
                                <img class="w-100" src="/img/blog/somali-blog-3.jpg" alt="Custom Portal & Analytics Dashboard">
                            </div>
                            <div class="vl-gallery-testimonial-2-con">
                                <h3 class="vl-gallery-testimonial-2-title"><a href="/service-web-dev">Custom Portal & Analytics Dashboard</a></h3>
                            </div>
                            <div class="vl-gallery-poligon">
                                <h3><a href="/service-web-dev">View Project</a></h3>
                                <a href="/service-web-dev"><span class="blu-bg"><i class="fa-regular fa-arrow-right"></i></span></a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>
        <!--================= Case Studies section End =================-->

        <%- include("partials/cta") %>

    </main>

    <%- include("partials/footer") %>

    <%- include("partials/progress_circle") %>

    <%- include("partials/footer_scripts") %>

</body>

</html>
