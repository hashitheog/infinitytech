<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head_css") %>
</head>

<body>

    <%- include("partials/loader") %>

    <%- include("partials/navbar") %>

    <main>

        <!--================= Banner section start =================-->
        <section class="vl-breadcrumb-bg p-relative z-index-1 fix pt-200 pb--70" style="background-image: url(/img/banner/vl-breadcrumb-bg.png);">
            <div class="container">
                <div class="row">
                    <div class="col-xl-6 col-md-6 mb-30">
                        <div class="vl-breadcrumb">
                            <h1 class="vl-fs-60 vl-white">Our Blog</h1>
                            <div class="vl-breadcrumb-list">
                                <span><a href="/">Home</a></span>
                                <span class="dvir"><i class="fa-solid fa-angle-right"></i></span>
                                <span class="active"><a href="#">Our Blog</a></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-6 col-md-6 mb-30">
                        <div class="vl-hero-img p-relative d-none d-lg-block">
                            <div class="vl-hero-shape-4">
                                <div class="vl-shape-2">
                                    <img src="/img/icons/vl-emoji-4.2.svg" alt="">
                                </div>
                                <div class="vl-shape-3">
                                    <img src="/img/icons/vl-emoji-4.3.svg" alt="">
                                </div>
                            </div>
                            <div class="vl-breadcrumb-fan">
                                <img class="w-100" src="/img/icons/vl-fan-sm.svg" alt="">
                            </div>
                            <div class="vl-breadcrumb-img">
                                <img src="/img/banner/infinity-hero-transparent.png" alt="Infinity Tech Blog" style="transform: scale(0.99); transform-origin: center center; max-height: 352px;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!--================= Banner section End =================-->

        <!--================= Blog section start =================-->
        <section class="vl-blog-sec pt-100 pb-70">
            <div class="container">
                <div class="row">
                    <!-- single blog item 1 -->
                    <div class="col-lg-6">
                        <div class="vl-single-blog-item vl-single-blog-item-3 inner-blog mb-30">
                            <div class="vl-single-blog-img vl-single-blog-img-4 br-8 fix p-relative">
                                <a href="/blog"><img class="w-100" src="/img/blog/somali-blog-1.jpg" alt="Somali Tech Transformation"></a>
                            </div>
                            <div class="vl-single-blog-4 p-relative z-index-1">
                                <div class="vl-single-blog-meta">
                                    <div class="vl-single-blog-meta-box mr-16">
                                        <div class="vl-single-blog-meta-box-icon mr-4">
                                            <span><img src="/img/icons/vl-calender-3.1.svg" alt=""></span>
                                        </div>
                                        <div class="vl-single-blog-meta-box-content">
                                            <a href="#">23 July 2026</a>
                                        </div>
                                    </div>
                                    <div class="vl-single-blog-meta-box mr-16">
                                        <div class="vl-single-blog-meta-box-icon mr-4">
                                            <span><img src="/img/icons/vl-user-3.2.svg" alt=""></span>
                                        </div>
                                        <div class="vl-single-blog-meta-box-content">
                                            <a href="#">Abubakar Hashi</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="vl-single-blog-content vl-single-blog-content-4 p-relative z-index-1">
                                    <h3 class="vl-single-blog-title vl-single-blog-title-4 pt-18 pb-12"><a href="/blog">Your Trusted Partner in Technology Transformation</a></h3>
                                    <p class="pb-24">Looking to stay ahead in the fast-paced world of technology? Our blog offers in-depth articles, case studies, & digital solutions for Somalia.</p>
                                    <a href="/blog" class="vl-readmore">Read More <span><i class="fa-regular fa-arrow-right"></i></span></a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- single blog item 2 -->
                    <div class="col-lg-6">
                        <div class="vl-single-blog-item vl-single-blog-item-3 inner-blog mb-30">
                            <div class="vl-single-blog-img vl-single-blog-img-4 br-8 fix p-relative">
                                <a href="/blog"><img class="w-100" src="/img/blog/somali-blog-2.jpg" alt="Somali IT Trends"></a>
                            </div>
                            <div class="vl-single-blog-4 p-relative z-index-1">
                                <div class="vl-single-blog-meta">
                                    <div class="vl-single-blog-meta-box mr-16">
                                        <div class="vl-single-blog-meta-box-icon mr-4">
