            <a href="https://wa.me/252615565249?text=Hello%20Infinity%20Tech%2C%20I%20would%20like%20to%20speak%20to%20a%20real%20person" target="_blank" rel="noopener noreferrer" class="wa-human-btn">
                <i class="fa-brands fa-whatsapp"></i> Chat on WhatsApp
            </a>
        </div>

        <!-- Chat Body / Wallpaper -->
        <div id="wa-chat-body">
            <div class="wa-date-divider">
                <span>TODAY</span>
            </div>

            <!-- Bot Initial Message -->
            <div class="wa-msg-row wa-msg-in">
                <div class="wa-bubble">
                    <p class="wa-msg-text">Asc! 👋 Welcome to Infinity Tech Somalia.</p>
                    <p class="wa-msg-text">Ask us about Mobile Apps, Web Dev, or School SaaS!</p>
                    <span class="wa-time">10:45 AM <i class="fa-solid fa-check-double wa-checks"></i></span>
                </div>
            </div>
        </div>

        <!-- Quick Question Pills -->
        <div class="wa-quick-pills">
            <button type="button" class="wa-pill" data-query="What mobile app features do you offer?">📱 Mobile Apps</button>
            <button type="button" class="wa-pill" data-query="Tell me about Web Application Dev.">🌐 Web Dev</button>
            <button type="button" class="wa-pill" data-query="How does School SaaS platform work?">🎓 School SaaS</button>
        </div>

        <!-- Clean Input Footer Bar -->
        <form id="wa-chat-form">
            <input type="text" id="wa-input" placeholder="Type a message..." autocomplete="off">
            <button type="submit" id="wa-send-btn" title="Send">
                <i class="fa-solid fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

