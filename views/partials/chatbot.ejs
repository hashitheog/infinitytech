<script>
document.addEventListener('DOMContentLoaded', function() {
    const trigger = document.getElementById('wa-fab-trigger');
    const closeBtn = document.getElementById('wa-close-btn');
    const windowModal = document.getElementById('wa-chat-window');
    const form = document.getElementById('wa-chat-form');
    const input = document.getElementById('wa-input');
    const body = document.getElementById('wa-chat-body');
    const pills = document.querySelectorAll('.wa-pill');

    let history = [];

    if (trigger && windowModal && closeBtn) {
        trigger.addEventListener('click', function() {
            windowModal.classList.toggle('wa-hidden');
            if (!windowModal.classList.contains('wa-hidden')) {
                input.focus();
            }
        });

        closeBtn.addEventListener('click', function() {
            windowModal.classList.add('wa-hidden');
        });
    }

    pills.forEach(pill => {
        pill.addEventListener('click', function() {
            const query = this.getAttribute('data-query');
            if (query) {
                sendWaMessage(query);
            }
        });
    });

    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            const text = input.value.trim();
            if (text) {
                sendWaMessage(text);
                input.value = '';
            }
        });
    }

    function getCurrentTime() {
        const now = new Date();
        let hours = now.getHours();
        let minutes = now.getMinutes();
        const ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12 || 12;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        return hours + ':' + minutes + ' ' + ampm;
    }

    function appendWaBubble(role, htmlContent) {
        const row = document.createElement('div');
        row.className = 'wa-msg-row ' + (role === 'user' ? 'wa-msg-out' : 'wa-msg-in');

        const bubble = document.createElement('div');
        bubble.className = 'wa-bubble';

        const timeStr = getCurrentTime();
        bubble.innerHTML = htmlContent + '<span class="wa-time">' + timeStr + ' <i class="fa-solid fa-check-double wa-checks"></i></span>';
        row.appendChild(bubble);
        body.appendChild(row);
        body.scrollTop = body.scrollHeight;
    }

    async function sendWaMessage(text) {
        appendWaBubble('user', '<p class="wa-msg-text">' + escapeWaText(text) + '</p>');
        history.push({ role: 'user', content: text });

        const typingId = 'wa-typing-' + Date.now();
        const typingRow = document.createElement('div');
        typingRow.className = 'wa-msg-row wa-msg-in';
        typingRow.id = typingId;
        typingRow.innerHTML = '<div class="wa-bubble"><p class="wa-msg-text" style="color:#8696A0; font-style:italic;">typing...</p></div>';
        body.appendChild(typingRow);
        body.scrollTop = body.scrollHeight;

        try {
            const res = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text, history: history.slice(-4) })
            });

            const data = await res.json();
            
            const typingElem = document.getElementById(typingId);
            if (typingElem) typingElem.remove();

            if (data.reply) {
                let formatted = data.reply
                    .replace(/!\[([^\]]*)\]\(([^\)]+)\)/g, '<img src="$2" alt="$1" class="chat-img">')
                    .replace(/\n/g, '<br>');

                appendWaBubble('bot', '<div class="wa-msg-text">' + formatted + '</div>');
                history.push({ role: 'assistant', content: data.reply });
            } else {
                appendWaBubble('bot', '<p class="wa-msg-text">We build Mobile Apps, Web Dev & School SaaS in Somalia. Want to chat on <a href="https://wa.me/252615565249" target="_blank" style="color:#25D366; font-weight:bold;">WhatsApp (+252615565249)</a>?</p>');
            }
        } catch (err) {
            const typingElem = document.getElementById(typingId);
            if (typingElem) typingElem.remove();

            appendWaBubble('bot', '<p class="wa-msg-text">Contact our team directly on <a href="https://wa.me/252615565249" target="_blank" style="color:#25D366; font-weight:bold;">WhatsApp (+252615565249)</a>!</p>');
        }
    }

    function escapeWaText(str) {
        return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }
});
</script>
